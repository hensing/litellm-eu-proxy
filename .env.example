# ─── LightOn AI ────────────────────────────────────────────────────────────────
# Sign up and generate an API key at: https://paradigm.lighton.ai
LIGHTON_API_KEY=your_lighton_api_key_here

# ─── Scaleway Generative APIs ──────────────────────────────────────────────────
# Create an API key at: https://console.scaleway.com → IAM → API Keys
SCW_SECRET_KEY=your_scaleway_secret_key_here

# ─── Infomaniak AI ─────────────────────────────────────────────────────────────
# 1. Generate an API token at: https://manager.infomaniak.com → API tokens
# 2. Find your product ID in Infomaniak Manager under your AI product
# 3. Paste the full base URL below (replace YOUR_PRODUCT_ID):
INFOMANIAK_API_BASE=https://api.infomaniak.com/2/ai/YOUR_PRODUCT_ID/openai/v1
INFOMANIAK_API_KEY=your_infomaniak_api_token_here

# ─── LiteLLM Proxy ─────────────────────────────────────────────────────────────
# Master key to authenticate against the proxy — choose any strong secret string.
# All clients (e.g. paperless-gpt) must send this as the Bearer token.
LITELLM_MASTER_KEY=your_master_key_here
