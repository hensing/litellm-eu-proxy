# ─── Mistral AI ────────────────────────────────────────────────────────────────
# Create an API key at: https://console.mistral.ai → API Keys
MISTRAL_API_KEY=your_mistral_api_key_here

# ─── PostgreSQL ────────────────────────────────────────────────────────────────
# Password for the internal LiteLLM database — choose any strong secret string.
POSTGRES_PASSWORD=your_postgres_password_here

# ─── LiteLLM Proxy ─────────────────────────────────────────────────────────────
# Master key to authenticate against the proxy — choose any strong secret string.
# All clients (e.g. paperless-gpt) must send this as the Bearer token.
LITELLM_MASTER_KEY=your_master_key_here

# Public-facing URL of the proxy (used in Swagger UI links and email alerts).
LITELLM_PROXY_URL=https://litellm.example.com

# ─── SMTP (for budget alerts and user invitations) ──────────────────────────────
SMTP_HOST=mail.example.com
SMTP_PORT=587
SMTP_USERNAME=your_smtp_username_here
SMTP_PASSWORD=your_smtp_password_here
SMTP_SENDER_EMAIL=litellm@example.com
